Create an HTML page with a table of 10 employees (name, department, salary, start date).
Add a <thead> and <tbody>.
Add a simple JavaScript snippet that sorts the table by clicking column headers.
Bonus: add alternating row colors with CSS.




<!DOCTYPE html>
<html>
<head>
    <title>Bug Crushers</title>

    <style>
        table {
                      width: 30%;
        }

        th, td {
            border: 1px solid black;
            padding: 2px;
            cursor: pointer;
        }

        th {
            background-color: lightgreen;
        }

        /* alternating rows */
        tr:nth-child(even) {
            background-color: lightblue;
        }
       tr:nth-child(odd) {
            background-color: lightyellow;
        }
    </style>
</head>

<body>

<h2>Bug Crushers</h2>

<table id="myTable">
    <thead>
        <tr>
            <th onclick="sortTable(0)">Name</th>
            <th onclick="sortTable(1)">Project</th>
            <th onclick="sortTable(2)">Email</th>
            <th onclick="sortTable(3)">Start Date</th>
        </tr>
    </thead>

    <tbody>
         <tr><td>Anita</td><td>IT</td><td>60000</td><td>2020-03-10</td></tr>
        <tr><td>Vikram</td><td>Finance</td><td>55000</td><td>2019-11-25</td></tr>
        <tr><td>Pooja</td><td>Marketing</td><td>45000</td><td>2022-01-05</td></tr>
        <tr><td>Kiran</td><td>IT</td><td>70000</td><td>2018-07-19</td></tr>
        <tr><td>Neha</td><td>HR</td><td>42000</td><td>2021-09-12</td></tr>
        <tr><td>Arjun</td><td>Finance</td><td>50000</td><td>2020-12-01</td></tr>
        <tr><td>Sneha</td><td>Marketing</td><td>48000</td><td>2023-02-20</td></tr>
        <tr><td>Rahul</td><td>IT</td><td>65000</td><td>2019-05-30</td></tr>
        <tr><td>Meena</td><td>HR</td><td>43000</td><td>2022-08-18</td></tr>
    </tbody>
</table>

<script>
function sortTable(n) {
    var table = document.getElementById("myTable");
    var rows = Array.from(table.rows).slice(1);

    rows.sort(function(a, b) {
        return a.cells[n].innerHTML.localeCompare(b.cells[n].innerHTML);
    });

    rows.forEach(function(row) {
        table.tBodies[0].appendChild(row);
    });
}
</script>

</body>
</html>
